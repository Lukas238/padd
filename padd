#!/usr/bin/env node

/**
 * padd - Personal Access Data Delivery
 *
 * Connection helpers + CLI utilities for data platforms.
 * Automatically discovers domain scripts when run from a workspace.
 *
 * @version 1.2.0
 * @license MIT
 */

import { fileURLToPath } from 'url';
import path from 'path';
import fs from 'fs';
import { spawn } from 'child_process';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

// ============================================================================
// Version & Help
// ============================================================================

const VERSION = '1.2.6';

function showVersion() {
  console.log(`padd v${VERSION}`);
  console.log('Personal Access Data Delivery');
  process.exit(0);
}

function showHelp(domainScripts = null) {
  console.log(`\n📦 padd v${VERSION} - Personal Access Data Delivery`);
  console.log(`Connection helpers + CLI utilities for data platforms\n`);
  
  console.log(`USAGE
  padd <command> [options]\n`);
  
  console.log(`CORE COMMANDS
  auth       Manage authentication (init, refresh)
  config     Manage configuration (init, validate)\n`);
  
  if (domainScripts && domainScripts.scripts && domainScripts.scripts.length > 0) {
    const domainPath = path.relative(process.cwd(), domainScripts.dir) || '.';
    const domainName = domainScripts.packageName || domainScripts.domain;
    const pathInfo = domainPath === '.' ? '' : ` @ ${domainPath}`;
    console.log(`DOMAIN SCRIPTS (${domainName}${pathInfo})
${domainScripts.scripts.map(s => `  padd ${s.name.padEnd(21)} ${s.description}`).join('\n')}\n`);
  }
  
  console.log(`LIBRARY MODULES
  - SharePointClient     Excel/file operations, uploads
  - ConfluenceClient     Page creation, updates
  - csv-utils            CSV/array conversions
  - refreshProvider      Auto-refresh auth tokens
  - loadAuth             Find & load auth config\n`);
  
  console.log(`Run 'padd <command> --help' for command details`);
  console.log(`Docs: https://github.com/Lukas238/padd\n`);
  process.exit(0);
}

// ============================================================================
// Domain Scripts Discovery
// ============================================================================

function findDomainScripts() {
  try {
    // Walk up from CWD looking for package.json with domain field
    let currentDir = process.cwd();
    const root = path.parse(currentDir).root;
    
    while (currentDir !== root) {
      const pkgPath = path.join(currentDir, 'package.json');
      if (fs.existsSync(pkgPath)) {
        const pkg = JSON.parse(fs.readFileSync(pkgPath, 'utf8'));
        
        // Check if this package.json has a domain field
        if (pkg.domain && pkg.scripts) {
          const allScriptNames = Object.keys(pkg.scripts);
          const scripts = Object.entries(pkg.scripts || {})
            .filter(([name]) => {
              // Exclude npm lifecycle hooks like preinstall, postbuild
              // But keep scripts like pre-talk, post-talk (they have hyphens)
              if (name.startsWith('pre') || name.startsWith('post')) {
                // If it has a hyphen, it's a regular script, keep it
                if (name.includes('-')) return true;
                // Check if it's a lifecycle hook for another script
                const baseScript = name.startsWith('pre') ? name.slice(3) : name.slice(4);
                // If the base script exists, it's a lifecycle hook, exclude it
                return !allScriptNames.includes(baseScript);
              }
              return true;
            })
            .map(([name, cmd]) => {
              // Extract meaningful description from command
              let description = '';
              if (cmd.includes('scripts/')) {
                const scriptFile = cmd.split('scripts/')[1]?.split(/\s/)[0];
                description = scriptFile ? path.basename(scriptFile, '.js').replace(/_/g, ' ') : '';
              } else {
                description = cmd.substring(0, 50);
              }
              return { name, description };
            });
          
          return { 
            domain: pkg.domain, 
            packageName: pkg.name,
            scripts, 
            dir: currentDir 
          };
        }
      }
      
      currentDir = path.dirname(currentDir);
    }
  } catch (err) {
    // Silently fail - no domain scripts found
  }
  
  return null;
}

// ============================================================================
// Main Dispatcher
// ============================================================================

async function main() {
  const args = process.argv.slice(2);

  // Discover domain scripts first
  const domainScripts = findDomainScripts();

  // Handle version flag
  if (args.includes('--version') || args.includes('-v')) {
    showVersion();
  }

  // Handle help flag (only if no command provided)
  if (args.length === 0 || (args.includes('--help') && !args[0]) || (args.includes('-h') && !args[0])) {
    showHelp(domainScripts);
  }

  const command = args[0];
  
  // Handle main help for specific commands
  if ((command === '--help' || command === '-h') && args.length === 1) {
    showHelp();
  }

  const subArgs = args.slice(1);

  // Route to core commands
  if (command === 'auth') {
    const { run } = await import('./commands/auth.js');
    await run(subArgs);
    return;
  }

  if (command === 'config') {
    const { run } = await import('./commands/config.js');
    await run(subArgs);
    return;
  }

  if (command === 'utils') {
    const utilCommand = subArgs[0];
    const utilArgs = subArgs.slice(1);

    if (!utilCommand) {
      console.error(`\n❌ Missing utility command`);
      console.error(`   Available: confluence, sharepoint`);
      console.error(`   Run: padd utils confluence --help\n`);
      process.exit(1);
    }

    if (utilCommand === 'confluence') {
      const { run } = await import('./commands/utils/confluence.js');
      await run(utilArgs);
      return;
    }

    if (utilCommand === 'sharepoint') {
      const { run } = await import('./commands/utils/sharepoint.js');
      await run(utilArgs);
      return;
    }

    console.error(`\n❌ Unknown utility command: ${utilCommand}`);
    console.error(`   Available: confluence, sharepoint`);
    console.error(`   Run: padd utils ${utilCommand} --help\n`);
    process.exit(1);
  }

  // Try domain script execution
  if (domainScripts && domainScripts.scripts) {
    const scriptExists = domainScripts.scripts.find(s => s.name === command);
    
    if (scriptExists) {
      console.log(`🔧 Running domain script: ${command}\n`);
      
      // Get the actual command from package.json
      const pkg = JSON.parse(fs.readFileSync(path.join(domainScripts.dir, 'package.json'), 'utf8'));
      const scriptCommand = pkg.scripts[command];
      
      // Parse command: "node scripts/feedback-pull.js" -> ["node", "scripts/feedback-pull.js"]
      const [cmd, ...cmdArgs] = scriptCommand.split(/\s+/);
      
      // Resolve script path relative to domain root
      // Important: We resolve to absolute path but don't change CWD
      // This way process.cwd() inside the script = where user ran padd
      let resolvedCmd = cmd;
      const resolvedArgs = cmdArgs.map(arg => {
        // If arg looks like a relative path, resolve it relative to domain root
        if (!arg.startsWith('-') && !path.isAbsolute(arg)) {
          return path.resolve(domainScripts.dir, arg);
        }
        return arg;
      });
      
      // Execute without shell to preserve CWD exactly
      const scriptProcess = spawn(resolvedCmd, [...resolvedArgs, ...subArgs], {
        stdio: 'inherit',
        cwd: process.cwd() // Explicitly maintain current working directory
      });
      
      scriptProcess.on('close', (code) => {
        process.exit(code || 0);
      });
      
      return;
    }
  }

  // Unknown command
  console.error(`\n❌ Unknown command: ${command}`);
  if (domainScripts && domainScripts.scripts && domainScripts.scripts.length > 0) {
    console.error(`\n   Available domain scripts:`);
    domainScripts.scripts.forEach(s => console.error(`     padd ${s.name}`));
  }

  console.error(`   Run: padd --help\n`);
  process.exit(1);
}

// Run main
main().catch(err => {
  console.error(`\n❌ Error: ${err.message}\n`);
  process.exit(1);
});
