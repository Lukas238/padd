#!/usr/bin/env node

/**
 * padd - Personal Access Display Device
 *
 * Context-aware CLI framework for operational automation.
 * Automatically discovers and dispatches to domain-specific commands.
 *
 * Architecture:
 * - Core commands: auth, config (global, always available)
 * - Utility commands: utils confluence, utils sharepoint (direct API access)
 * - Domain commands: Auto-discovered from workspace (e.g., talk, report)
 *
 * Usage:
 *   padd <command> [options]
 *   padd --help
 *   padd --version
 *
 * @version 1.0.0
 * @license MIT
 */

import { fileURLToPath } from 'url';
import path from 'path';
import fs from 'fs';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

// ============================================================================
// Version & Help
// ============================================================================

const VERSION = '1.0.0';

function showVersion() {
  console.log(`padd v${VERSION}`);
  console.log('Personal Access Display Device');
  process.exit(0);
}

function showHelp() {
  console.log(`
