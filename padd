// ============================================================================
// Main Dispatcher
// ============================================================================

async function main() {
  const args = process.argv.slice(2);

  // Handle version/help flags
  if (args.length === 0 || args.includes('--help') || args.includes('-h')) {
    showHelp();
  }

  if (args.includes('--version') || args.includes('-v')) {
    showVersion();
  }

  const command = args[0];

  // Route to core commands
  if (command === 'auth') {
    console.log('рҹ”җ Auth commands coming soon...');
    process.exit(0);
  }

  if (command === 'config') {
    console.log('рҹ”§ Config commands coming soon...');
    process.exit(0);
  }

  if (command === 'utils') {
    console.log('рҹ”Ё Utility commands coming soon...');
    process.exit(0);
  }

  // Try domain command discovery
  console.log(`рҹ”Қ Domain command discovery coming soon...`);
  console.log(`   Looking for: ${command}`);
  process.exit(1);
}

// Run main
main().catch(err => {
  console.error(`\nвқҢ Error: ${err.message}\n`);
  process.exit(1);
});
